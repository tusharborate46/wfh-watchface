# Server
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=wfh_watchface
JWT_SECRET=replace-with-a-long-random-secret
EMBEDDING_ENCRYPTION_KEY=replace-with-at-least-32-bytes-of-secret-material
CLIENT_ORIGIN=http://localhost:5173
PORT=4000

# Optional alert delivery. If neither is configured, UNKNOWN_FACE alerts are logged to stderr.
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM=alerts@example.com

# Client (copy to client/.env for local Vite development)
VITE_API_URL=http://localhost:4000
